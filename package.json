  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/mdlutz24/drupal-meeting-parser/issues"
  },
  "homepage": "https://github.com/mdlutz24/drupal-meeting-parser#readme",
  "devDependencies": {
    "copyfiles-ng": "^2.4.6",
    "web-ext": "^10.1.0"
  }
}
